# ── TopstepX / ProjectX Gateway API credentials ──────────────────────────────
# Generate an API key in TopstepX:  Settings → API Access → Generate Key
# Your username is your TopstepX login (NOT your email, unless that is your login).
TOPSTEPX_USERNAME=
TOPSTEPX_API_KEY=

# Optional: pin a specific account. If blank, the first active account is used.
# Find it via the /api/Account/search response (the numeric "id").
TOPSTEPX_ACCOUNT_ID=

# Optional: override the API base URL (defaults to the Topstep production gateway).
# TOPSTEPX_BASE_URL=https://api.topstepx.com

# Optional: trading-day timezone used to group daily P&L (Topstep resets 5pm CT).
# TOPSTEP_TZ=America/Chicago

# ── Telegram RSI alerts ──────────────────────────────────────────────────────
# 1. Create a bot with @BotFather → copy the token here.
# 2. Message your bot once, then GET /api/telegram/updates to find your chat id.
# 3. Put approved chat ids (comma-separated) in TELEGRAM_CHAT_IDS — ONLY these
#    "registered phones" receive alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Optional: protects the /api/rsi-check cron endpoint (Vercel Cron sends it).
# CRON_SECRET=
